# Kilnify environment configuration. Copy to .env and adjust as needed.

# SQLAlchemy database URL (SQLite for dev, PostgreSQL for prod).
DATABASE_URL=sqlite:///./kilnify.db
# DATABASE_URL=postgresql://user:password@localhost:5432/kilnify

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
